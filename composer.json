{
    "name": "seu-nome/etecast",
    "description": "Plataforma de streaming educacional ETECAST",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Jhonathan Rennan",
            "email": "jhonathan.rsilva@professor.educacao.pe.gov.br"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-pdo": "*",
        "ext-redis": "*",
        "bramus/router": "^1.2",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
