# Arquivo de segredos
.env

# Dependências do Composer
/vendor/

# Logs (ignora todos os arquivos .log, exceto o .keep)
/storage/logs/*.log
!/storage/logs/.keep

# Cache
/storage/cache/
!/storage/cache/.keep

# Backups
/storage/backups/
!/storage/backups/.keep

# Uploads temporários da fila
/storage/uploads_queue/
!/storage/uploads_queue/.keep

# Mídia processada (vídeos, HLS, PDFs)
/media_protected/
!/media_protected/.keep

# Imagens de capa enviadas (públicas)
/public/assets/covers/
!/public/assets/covers/.keep